# Used by: docker compose --env-file .env.docker up --build
# Copy to .env.docker and replace every value with long random strings (especially in production).

STRAPI_APP_KEYS=replaceWithCommaSeparatedFourRandomKeys
STRAPI_API_TOKEN_SALT=replaceWithRandomString
STRAPI_ADMIN_JWT_SECRET=replaceWithRandomString
STRAPI_TRANSFER_TOKEN_SALT=replaceWithRandomString
STRAPI_JWT_SECRET=replaceWithRandomString

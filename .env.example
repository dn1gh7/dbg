# Copy to .env.local and adjust. Leave VITE_STRAPI_URL unset to use built-in static content only.

# Production: your public Strapi URL (enable CORS for the site origin).
# VITE_STRAPI_URL=https://cms.your-domain.de

# Local Strapi with Vite proxy (see vite.config.ts): avoids configuring Strapi CORS for the dev server.
# VITE_STRAPI_URL=http://localhost:8080/strapi-api

# Optional if API permissions require authentication:
# VITE_STRAPI_API_TOKEN=
